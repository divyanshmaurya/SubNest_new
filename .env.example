# AI Studio automatically injects this at runtime from user secrets.
GEMINI_API_KEY="your-real-gemini-key"

# AI Studio automatically injects this at runtime with the app URL.
APP_URL="https://your-app-url"

# Send lead notification emails to this inbox.
NOTIFICATION_EMAIL_TO="contact@subnest.ai"

# Send the email from this Gmail account using an App Password.
GMAIL_USER="subnest.ai@gmail.com"
GMAIL_APP_PASSWORD="your-16-char-gmail-app-password"
