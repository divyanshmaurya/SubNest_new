# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Lead notification recipient. Defaults to subnest.ai@gmail.com if omitted.
NOTIFICATION_EMAIL_TO="subnest.ai@gmail.com"

# Recommended: Resend API settings for chatbot lead notification emails.
RESEND_API_KEY="re_123"
EMAIL_FROM="SubNest Website <onboarding@resend.dev>"

# Optional SMTP fallback if you prefer SMTP instead of an email API.
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="smtp-user"
SMTP_PASS="smtp-password"
SMTP_FROM="SubNest Website <no-reply@subnest.ai>"
